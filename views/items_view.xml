<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_supplies_list" model="ir.ui.view">
        <field name="name">office.items.list</field>
        <field name="model">office.items</field>
        <field name="arch" type="xml">
                <list>
                    <field name="item_name"/>
                    <field name="category"/>
                    <field name="quantity"/>
                    <field name="price"/>
                    <field name="supplier"/>
                    <field name="reorder_level"/>
                </list>
        </field>
    </record>

    <record id="view_supplies_search" model="ir.ui.view">
        <field name="name">office.items.search</field>
        <field name="model">office.items</field>
        <field name="arch" type="xml">
            <search>
                <field name="item_name"/>
                <field name="category"/>
                <field name="quantity"/>
                <field name="price"/>
                <field name="supplier"/>
                <field name="reorder_level"/>
            </search>
        </field>

    </record>

    <record id="view_supplies_form" model="ir.ui.view">
        <field name="name">office.items.form</field>
        <field name="model">office.items</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_message_wizard" string="Send Message" type="object"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="item_name"/>
                            <field name="category"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="supplier"/>
                            <field name="reorder_level"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="office_items_action" model="ir.actions.act_window">
        <field name="name">items</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">office.items</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>