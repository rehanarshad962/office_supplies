<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_message_wizard_form" model="ir.ui.view">
        <field name="name">message.wizard.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Message">

                <group>
                    <field name="message"/>
                </group>
                <footer>
                    <button name="action_submit"
                    string="Submit"
                    type="object"
                    class="btn-primary"/>
                    <button string="Cancel"
                    special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_message_wizard" model="ir.actions.act_window">
        <field name="name">Send Message</field>
        <field name="res_model">message.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_message_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>